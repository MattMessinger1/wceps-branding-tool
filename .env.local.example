NEXT_PUBLIC_APP_NAME="WCEPS Branding Tool"

# Optional future integrations. The MVP runs deterministically without paid model access,
# but /api/generate-images will use this key when present.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_IMAGE_OUTPUT_FORMAT=webp
OPENAI_IMAGE_OUTPUT_COMPRESSION=70

# Optional Braintrust tracing and evals.
# Keep the API key server-side only; never expose it with NEXT_PUBLIC_.
BRAINTRUST_API_KEY=
BRAINTRUST_ORG_NAME="WCEPS"
BRAINTRUST_PROJECT_NAME="Brand Building"
BRAINTRUST_LOGGING_ENABLED=true
